APP_NAME="__AIAST_APP_NAME__"
APP_ID="__AIAST_APP_ID__"
APP_ENV=prod
APP_BIND_ADDRESS=__AIAST_BIND_ADDRESS__
APP_PORT=
APP_PORT_RANGE_START=__AIAST_PORT_RANGE_START__
APP_PORT_RANGE_END=__AIAST_PORT_RANGE_END__
APP_EXEC_START="python3 -m http.server ${APP_PORT:-46300} --bind ${APP_BIND_ADDRESS:-127.0.0.1}"
APP_HEALTHCHECK_URL=http://${APP_BIND_ADDRESS:-127.0.0.1}:${APP_PORT:-46300}/health
DATABASE_MODE=postgres
POSTGRES_HOST_BIND=127.0.0.1
PUBLISH_POSTGRES_PORT=false
POSTGRES_HOST=${POSTGRES_HOST_BIND}
POSTGRES_PORT=5432
POSTGRES_DB=__AIAST_APP_SLUG__
POSTGRES_USER=__AIAST_APP_SLUG__
POSTGRES_PASSWORD=
REDIS_HOST_BIND=127.0.0.1
PUBLISH_REDIS_PORT=false
REDIS_HOST=${REDIS_HOST_BIND}
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
SQLITE_PATH=${HOME}/.local/share/__AIAST_APP_SLUG__/app.sqlite3
LLM_CONFIG_PATH=ai/llm_config.yaml
SYSTEM_PACKAGES="python3 python3-venv curl"

# Optional dev/staging only: bootstrap a privileged user for local QA (never commit real values).
# See _system/AUTH_AND_ONBOARDING_PATTERNS.md. Keep false in production; use gitignored .env.local.
SEED_DEV_ADMIN=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
