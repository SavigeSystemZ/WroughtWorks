{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiaast.invalid/schemas/system-registry.schema.json",
  "title": "AIAST System Registry (contract graph)",
  "description": "Machine-readable registry of template-managed files. Each entry is a contract-graph node: it knows its authority tier, owner, validator, dependency edges, downstream scaffold policy, and drift severity. Generated by bootstrap/generate-system-registry.sh from _system/registry-contract-policy.json; enforced by bootstrap/check-registry-contract-graph.sh.",
  "type": "object",
  "required": ["template_name", "template_version", "managed_file_count", "entries"],
  "properties": {
    "template_name": {"type": "string"},
    "template_version": {"type": "string"},
    "system_readme_path": {"type": "string"},
    "managed_file_count": {"type": "integer", "minimum": 0},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path", "category", "kind", "size_bytes",
          "authority_level", "owned_by", "validator",
          "depends_on", "generates", "downstream_policy", "drift_severity"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "category": {"type": "string"},
          "kind": {"type": "string"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "authority_level": {"enum": ["core", "adapter", "context", "runtime-template", "validator", "generated"]},
          "owned_by": {"enum": ["contract", "generator", "human", "runtime"]},
          "validator": {"type": ["string", "null"]},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "generates": {"type": "array", "items": {"type": "string"}},
          "downstream_policy": {"enum": ["copy", "placeholder", "generate", "do-not-copy", "local-only"]},
          "drift_severity": {"enum": ["info", "warn", "fail"]}
        }
      }
    }
  }
}
