{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIAST Release Packet",
  "type": "object",
  "required": [
    "version",
    "timestamp",
    "source_root",
    "template_root",
    "head",
    "includes",
    "artifact_count",
    "artifact_index",
    "artifact_index_sha256",
    "checksums",
    "signature"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source_root": { "type": "string", "minLength": 1 },
    "template_root": { "type": "string", "minLength": 1 },
    "head": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" },
    "includes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "artifact_index": { "type": "string", "minLength": 1 },
    "artifact_index_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "checksums": { "type": "string", "minLength": 1 },
    "signature": {
      "type": "object",
      "required": [
        "scheme",
        "status",
        "signed_at",
        "signer",
        "artifact_index_sha256",
        "packet_payload_sha256"
      ],
      "properties": {
        "scheme": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["checksum_attested", "unsigned"]
        },
        "signed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "signer": { "type": "string", "minLength": 1 },
        "artifact_index_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "packet_payload_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
