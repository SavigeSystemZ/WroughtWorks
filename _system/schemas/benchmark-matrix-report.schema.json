{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIAST Benchmark Matrix Report",
  "type": "object",
  "required": [
    "timestamp",
    "matrix_root",
    "execute_mode",
    "isolation_strategy",
    "profiles",
    "archetypes",
    "modes",
    "total_cells",
    "pass_count",
    "fail_count",
    "cells"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "matrix_root": { "type": "string", "minLength": 1 },
    "apply_mode": { "type": "boolean" },
    "execute_mode": { "type": "boolean" },
    "isolation_strategy": {
      "type": "string",
      "enum": ["per-cell-scaffold", "shared-template", "none"]
    },
    "cell_repo_retention": {
      "type": "string",
      "enum": ["transient", "retained"]
    },
    "transient_cleanup": { "type": "boolean" },
    "profiles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "archetypes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "modes": {
      "type": "array",
      "items": { "type": "string", "enum": ["fast", "strict"] }
    },
    "limit_cells": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "total_cells": { "type": "integer", "minimum": 0 },
    "pass_count": { "type": "integer", "minimum": 0 },
    "fail_count": { "type": "integer", "minimum": 0 },
    "cells": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "profile",
          "archetype",
          "mode",
          "status",
          "executed",
          "isolated",
          "gates",
          "gate_count",
          "duration_sec",
          "failed_gate_names",
          "warning_gate_names"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "profile": { "type": "string", "minLength": 1 },
          "archetype": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "enum": ["fast", "strict"] },
          "status": { "type": "string", "enum": ["pass", "fail", "warn", "skip"] },
          "executed": { "type": "boolean" },
          "isolated": { "type": "boolean" },
          "repo_dir": { "type": "string" },
          "repo_retained": { "type": "boolean" },
          "app_name": { "type": "string" },
          "gates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "command", "status", "required"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "command": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "status": { "type": "string", "enum": ["pass", "fail", "warn", "skip"] },
                "required": { "type": "boolean" },
                "duration_sec": { "type": "integer", "minimum": 0 },
                "exit_code": { "type": "integer" },
                "stdout_bytes": { "type": "integer", "minimum": 0 },
                "stderr_bytes": { "type": "integer", "minimum": 0 },
                "stdout_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "stderr_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "stdout_tail": { "type": "string" },
                "stderr_tail": { "type": "string" },
                "warning_reason": { "type": "string" }
              }
            }
          },
          "gate_count": { "type": "integer", "minimum": 0 },
          "duration_sec": { "type": "integer", "minimum": 0 },
          "failed_gate_names": {
            "type": "array",
            "items": { "type": "string" }
          },
          "warning_gate_names": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
