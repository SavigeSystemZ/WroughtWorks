{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiaast.invalid/schemas/scaffold-isolation-gates.schema.json",
  "title": "AIAST Scaffold Isolation Gates Manifest",
  "description": "Ordered list of validators executed by bootstrap/check-scaffold-isolation-gate.sh. See _system/SCAFFOLD_ISOLATION_COMPLETION_GATE.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "default_mode", "modes", "gates"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description":    { "type": "string" },
    "default_mode":   { "type": "string", "enum": ["strict", "best-effort", "report-only"] },
    "modes": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "enum": ["strict", "best-effort", "report-only"] }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Gate" }
    }
  },
  "$defs": {
    "Gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "command", "args", "expected_rc", "severity_on_fail", "blocks_subsequent"],
      "properties": {
        "id":               { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
        "title":            { "type": "string", "minLength": 1 },
        "command":          { "type": "string", "pattern": "^bootstrap/[a-z][a-z0-9-]*\\.sh$" },
        "args":             { "type": "array", "items": { "type": "string" } },
        "expected_rc":      { "type": "integer", "minimum": 0, "maximum": 255 },
        "severity_on_fail": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "blocks_subsequent": { "type": "boolean" },
        "policy_ref":       { "type": "string" }
      }
    }
  }
}
