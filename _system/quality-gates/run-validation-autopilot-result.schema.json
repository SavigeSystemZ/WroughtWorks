{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIAST Run Validation Autopilot Result",
  "type": "object",
  "required": ["checks"],
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
