    "lint": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "typecheck": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "test": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "build": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "security_audit": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "install_smoke": { "type": "string", "enum": ["found", "missing", "not_applicable"] },
    "launch_render": { "type": "string", "enum": ["found", "missing", "not_applicable"] }
  },
  "additionalProperties": false
}
