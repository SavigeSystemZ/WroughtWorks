{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quality Score Policy",
  "type": "object",
  "required": [
    "version",
    "expected_weight_sum",
    "required_weight_keys",
    "weights",
    "labels"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "expected_weight_sum": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "required_weight_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "weights": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "min_score"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "min_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
