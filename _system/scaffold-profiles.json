{
  "version": "1.1.0",
  "default_profile": "standard",
  "base": {
    "include": [
      "*",
      "**/*"
    ],
    "exclude": [
      ".git/**",
      "**/.git/**",
      ".env",
      "**/.env",
      "**/.env.*",
      "!**/.env.example",
      "**/secrets/**",
      "**/secret/**",
      "**/node_modules/**",
      "**/venv/**",
      "**/.venv/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "bootstrap/.bin/**",
      "**/bootstrap/.bin/**",
      "**/.update_backups/**",
      "src/aiast-cli/internal/_deferred/**",
      "**/internal/_deferred/**",
      "MOS_TEMPLATE/**",
      "_META_AGENT_SYSTEM/**",
      "_TEMPLATE_FACTORY/**",
      "_MOS_TEMPLATE_FACTORY/**",
      "MOS_SOURCE_LIBRARY/**"
    ],
    "required_files": [
      ".installable-product-root",
      "AGENTS.md",
      "CODEX.md",
      "CLAUDE.md",
      "GEMINI.md",
      "README.md",
      "AIAST_VERSION.md",
      "_system/.template-version",
      "_system/SCAFFOLD_PROFILE_MATRIX.md",
      "_system/SCAFFOLD_INCLUDE_EXCLUDE_MANIFEST.md",
      "_system/scaffold-profiles.json",
      "_system/WORKSPACE_AUTHORITY_AND_CONTAINMENT_PROTOCOL.md",
      "_system/TEMPLATE_MOS_AND_BUILDER_APP_BOUNDARY.md",
      "_system/MOS_DOWNSTREAM_EXCLUSION_POLICY.md",
      "_system/mcp/MCP_PROJECT_ISOLATION_POLICY.md",
      "_system/APP_ARCHETYPE_ROUTING_MATRIX.md",
      "_system/APP_ARCHETYPE_PERSONA_CATALOG.md",
      "_system/INSTALLER_FIRST_GATE.md",
      "_system/APP_REPO_IDENTITY.md",
      "_system/APP_PERSONA_CONTRACT.md",
      "_system/personas/README.md",
      "app/README.md",
      "bootstrap/init-project.sh",
      "bootstrap/update-template.sh",
      "bootstrap/install-missing-files.sh",
      "bootstrap/scaffold-system.sh",
      "bootstrap/render-scaffold-profile.sh",
      "bootstrap/validate-scaffold-output.sh",
      "bootstrap/check-scaffold-required-files.sh",
      "bootstrap/check-mos-downstream-exclusion.sh",
      "bootstrap/check-mcp-project-isolation.sh",
      "bootstrap/validate-system.sh",
      "bootstrap/aiast-cli",
      "bootstrap/build-aiast-cli.sh",
      "_system/PROJECT_LOCAL_SELF_IMPROVEMENT_PROTOCOL.md",
      "_system/SELF_WRITING_BOUNDARY_AND_ROLLBACK.md",
      "_system/APP_SPECIFIC_CONTEXT_AUTHORING_STANDARD.md",
      "_system/APP_CONTEXT_FILE_MATRIX.md",
      "_system/self-improvement/README.md",
      "_system/app-context/README.md"
    ],
    "forbidden_downstream_paths": [
      ".env",
      "**/.env",
      "**/secrets/**",
      "MOS_TEMPLATE/**",
      "_META_AGENT_SYSTEM/**",
      "_TEMPLATE_FACTORY/**",
      "_MOS_TEMPLATE_FACTORY/**",
      "MOS_SOURCE_LIBRARY/**"
    ],
    "generated_files": [
      "_system/.template-install.json",
      "_system/KEY.md",
      "_system/SYSTEM_REGISTRY.json",
      "_system/INTEGRITY_MANIFEST.sha256",
      "_system/REPO_OPERATING_PROFILE.md",
      "_system/repo-operating-profile.json",
      "_system/SUPER_TEMPLATE_MASTER_MAP.md",
      "_system/CAPABILITIES.md"
    ],
    "required_validators": [
      "validate-scaffold-output",
      "check-scaffold-required-files",
      "check-mos-downstream-exclusion",
      "check-mcp-project-isolation",
      "check-awareness",
      "validate-system"
    ]
  },
  "profiles": [
    {
      "id": "minimal",
      "installable": true,
      "maintainer_only": false,
      "downstream_mutable": true,
      "include": [],
      "exclude": [],
      "required_files": [],
      "optional_files": [],
      "required_validators": [
        "validate-scaffold-output",
        "check-scaffold-required-files",
        "check-system-awareness"
      ],
      "notes": "Smallest supported app-agent operating layer. Current implementation keeps the full installable AIAST contract until a narrowed minimal profile has its own strict validator."
    },
    {
      "id": "standard",
      "installable": true,
      "maintainer_only": false,
      "downstream_mutable": true,
      "include": [],
      "exclude": [],
      "required_files": [],
      "optional_files": [],
      "required_validators": [
        "validate-scaffold-output",
        "check-scaffold-required-files",
        "check-mos-downstream-exclusion",
        "validate-system"
      ],
      "notes": "Default downstream app profile. Includes the full installable AIAST product and excludes parent-template, MOS, factory, secret, and transient surfaces."
    },
    {
      "id": "advanced",
      "installable": true,
      "maintainer_only": false,
