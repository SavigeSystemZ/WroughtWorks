    "bootstrap/generate-host-adapters.sh":             ["CLAUDE.md", "CODEX.md", "GEMINI.md", "WINDSURF.md", "ANTIGRAVITY.md", ".cursorrules", ".windsurfrules", ".github/copilot-instructions.md", "_system/host-adapter-manifest.json"]
  }
