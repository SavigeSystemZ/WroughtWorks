    "CLAUDE.md":                               "check-host-adapter-alignment.sh",
    "CODEX.md":                                "check-host-adapter-alignment.sh",
    "GEMINI.md":                               "check-host-adapter-alignment.sh",
    "WINDSURF.md":                             "check-host-adapter-alignment.sh",
    "ANTIGRAVITY.md":                          "check-host-adapter-alignment.sh",
    ".cursorrules":                            "check-host-adapter-alignment.sh",
    ".windsurfrules":                          "check-host-adapter-alignment.sh",
    ".github/copilot-instructions.md":         "check-host-adapter-alignment.sh"
  },
  "core_validator": "validate-system.sh",
  "generator_outputs": {
    "bootstrap/generate-system-registry.sh":           ["_system/SYSTEM_REGISTRY.json"],
    "bootstrap/generate-system-key.sh":                ["_system/KEY.md"],
    "bootstrap/generate-super-template-master-map.sh": ["_system/SUPER_TEMPLATE_MASTER_MAP.md"],
    "bootstrap/generate-capabilities-sheet.sh":        ["_system/CAPABILITIES.md"],
