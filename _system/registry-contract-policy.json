{
  "_comment": "Policy that drives the SYSTEM_REGISTRY.json contract-graph fields. Consumed by bootstrap/generate-system-registry.sh and enforced by bootstrap/check-registry-contract-graph.sh. category_map covers every category aiaast_path_category can emit; generated_paths overrides (authority=generated, owned_by=generator, drift_severity=fail) and names the validator that proves the artifact is current.",
  "version": "1.0.0",
  "authority_levels": ["core", "adapter", "context", "runtime-template", "validator", "generated"],
  "owned_by_values": ["contract", "generator", "human", "runtime"],
  "drift_severities": ["info", "warn", "fail"],
  "downstream_policies": ["copy", "placeholder", "generate", "do-not-copy", "local-only"],
  "category_map": {
    "system-core":        {"authority": "core",             "owned_by": "contract",  "drift_severity": "fail"},
    "entrypoint":         {"authority": "core",             "owned_by": "contract",  "drift_severity": "fail"},
    "system-metadata":    {"authority": "generated",        "owned_by": "generator",  "drift_severity": "fail"},
    "system-context":     {"authority": "context",          "owned_by": "human",      "drift_severity": "warn"},
    "working-state":      {"authority": "context",          "owned_by": "human",      "drift_severity": "info", "downstream_policy": "placeholder"},
    "bootstrap":          {"authority": "validator",        "owned_by": "human",      "drift_severity": "warn"},
    "cursor-agent":       {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "cursor-command":     {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "cursor-rule":        {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "cursor-skill":       {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "cursor-overlay":     {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "copilot-overlay":    {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "host-settings-app":  {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "host-settings-meta": {"authority": "adapter",          "owned_by": "generator",  "drift_severity": "warn"},
    "prompting":          {"authority": "adapter",          "owned_by": "human",      "drift_severity": "warn"},
    "review-playbook":    {"authority": "adapter",          "owned_by": "human",      "drift_severity": "warn"},
    "mcp":                {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "warn"},
    "packaging":          {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "warn"},
    "systemd":            {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "warn"},
    "ci":                 {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "warn"},
    "plugin":             {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "warn"},
    "starter-blueprint":  {"authority": "runtime-template", "owned_by": "human",      "drift_severity": "info", "downstream_policy": "placeholder"},
    "unclassified":       {"authority": "context",          "owned_by": "human",      "drift_severity": "warn"}
  },
  "generated_paths": {
    "_system/SYSTEM_REGISTRY.json":            "check-registry-contract-graph.sh",
    "_system/KEY.md":                          "generate-system-key.sh",
    "_system/SUPER_TEMPLATE_MASTER_MAP.md":    "check-master-map-completeness.sh",
    "_system/INTEGRITY_MANIFEST.sha256":       "verify-integrity.sh",
    "_system/CAPABILITIES.md":                 "generate-capabilities-sheet.sh",
    "_system/CAPABILITY_MATRIX.json":          "discover-plugins.sh",
    "_system/host-adapter-manifest.json":      "check-host-adapter-alignment.sh",
