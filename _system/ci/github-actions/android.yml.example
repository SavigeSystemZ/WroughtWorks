name: android

on:
  workflow_dispatch:
  pull_request:
    paths:
      - "mobile/**"

jobs:
  android:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"
      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: stable
      - name: Flutter pub get
        run: |
          if test -f mobile/flutter/pubspec.yaml; then
            cd mobile/flutter
            flutter pub get
          else
            echo "No Flutter scaffold present"
          fi
      - name: Android build smoke
        run: |
          if test -f mobile/flutter/pubspec.yaml; then
            cd mobile/flutter
            flutter build apk --debug
          else
            echo "No Flutter scaffold present"
          fi
